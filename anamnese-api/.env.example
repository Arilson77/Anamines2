# =============================================
# BANCO DE DADOS
# =============================================
DATABASE_URL=postgresql://usuario:senha@localhost:5432/anamnese_db

# Banco de dados para testes (não use o banco de produção!)
DATABASE_URL_TEST=postgresql://usuario:senha@localhost:5432/anamnese_test

# =============================================
# JWT — gere um segredo forte (mín. 64 chars):
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================
JWT_SECRET=seu_segredo_aqui_minimo_64_caracteres

# =============================================
# SERVIDOR
# =============================================
PORT=3001
FRONTEND_URL=http://localhost:3000

# =============================================
# SMTP (para envio de e-mails)
# =============================================
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_smtp

# =============================================
# STRIPE (pagamentos e assinaturas)
# Obtenha em: https://dashboard.stripe.com/apikeys
# =============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================
# SENTRY (monitoramento de erros)
# Obtenha em: https://sentry.io/settings/projects/
# =============================================
SENTRY_DSN=https://...@sentry.io/...

# =============================================
# LOGSNAG (rastreamento de eventos)
# Obtenha em: https://logsnag.com/dashboard
# =============================================
LOGSNAG_TOKEN=seu_token_logsnag
LOGSNAG_PROJECT=anamnese
